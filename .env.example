# EvoMate local environment
EVOMATE_API_PORT=8787
EVOMATE_WEB_PORT=3000
EVOMATE_STATE_DIR=./memory/evomate

# Local EvoMap GEP MCP mode
GEP_ASSETS_DIR=./assets
GEP_MEMORY_DIR=./memory/evolution

# Optional remote EvoMap mode
EVOMAP_HUB_URL=https://evomap.ai
EVOMAP_NODE_ID=
EVOMAP_API_KEY=
EVOMAP_NODE_SECRET=

# Optional EvoMap OpenAI-compatible LLM signal extractor
# Use .env.local for real keys; do not commit secrets.
EVOMAP_LLM_BASE_URL=https://api.evomap.ai/v1
EVOMAP_LLM_API_KEY=sk-evomap-your-key-here
EVOMAP_LLM_MODEL=evomap-claude-opus-4-7
EVOMAP_LLM_TIMEOUT_MS=12000
EVOMAP_LLM_DISABLED=0

# Codex execution worker
CODEX_BIN=codex
CODEX_DEFAULT_CWD=.
